{
  "schemaVersion": 1,
  "key": "google-add-work-item-to-sheets-oauth",
  "name": "Google - Add Work Item to Sheets (OAuth)",
  "description": "Adds work items to a Google sheet on work item events",
  "category": "Google",
  "flows": [
    "google_add_work_item_to_sheets_oauth.json"
  ],
  "icon": "google.png",
  "author": "Rixter AB",
  "createdAt": "2026-06-14",
  "credentialDefinitions": [
    {
      "key": "oauth2-googlei",
      "name": "Googlei",
      "type": "OAUTH2",
      "data": {
        "config": {
          "url": {
            "authorizeUrl": "https://accounts.google.com/o/oauth2/v2/auth?access_type=offline&prompt=consent&include_granted_scopes=true",
            "accessTokenUrl": "https://oauth2.googleapis.com/token"
          },
          "grantType": "code",
          "scope": "https://www.googleapis.com/auth/spreadsheets",
          "headerPrefix": "Bearer",
          "includeState": true,
          "includeScopeInAccessTokenReq": false,
          "sendParamsAs": "query_params",
          "urlEncode": false
        }
      }
    }
  ]
}