      "type": "WEB_REQUEST_ACTION_TYPE",
      "body": "{\n  \"$schema\": \"https://api.stg.atlassian.com/jsm/assets/imports/external/schema/versions/2021_09_15\",\n  \"schema\": {\n    \"objectSchema\": {\n      \"name\": \"IT\",\n      \"description\": \"Data imported from External API\",\n      \"objectTypes\": [\n        {\n          \"name\": \"API Import\",\n          \"description\": \"...\",\n          \"attributes\": [\n            {\n              \"name\": \"Name\",\n              \"description\": \"\",\n              \"type\": \"text\",\n              \"label\": true\n            },\n            {\n              \"name\": \"ExternalId\",\n              \"description\": \"\",\n              \"type\": \"text\"\n            }\n          ]\n        }\n      ]\n    }\n  },\n  \"mapping\": {\n    \"objectTypeMappings\": [\n      {\n        \"objectTypeName\": \"API Import\",\n        \"selector\": \"api_response\",\n        \"description\": \"Mapping for API Response\",\n        \"attributesMapping\": [\n          {\n            \"attributeName\": \"Name\",\n            \"attributeLocators\": [\n              \"displayName\"\n            ]\n          },\n          {\n            \"attributeName\": \"ExternalId\",\n            \"attributeLocators\": [\n              \"id\"\n            ],\n            \"externalIdPart\": true\n          }\n        ]\n      }\n    ]\n  }\n}",
