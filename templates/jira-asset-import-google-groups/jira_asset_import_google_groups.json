      "type": "WEB_REQUEST_ACTION_TYPE",
      "body": "{\n  \"$schema\": \"https://api.stg.atlassian.com/jsm/assets/imports/external/schema/versions/2021_09_15\",\n  \"schema\": {\n    \"objectSchema\": {\n      \"name\": \"{{_flow.assetSchemaName}}\",\n      \"description\": \"Data imported from External API\",\n      \"objectTypes\": [\n        {\n          \"name\": \"Google Groups\",\n          \"description\": \"...\",\n          \"attributes\": [\n            {\n              \"name\": \"Name\",\n              \"description\": \"\",\n              \"type\": \"text\",\n              \"label\": true\n            },\n            {\n              \"name\": \"ExternalId\",\n              \"description\": \"\",\n              \"type\": \"text\"\n            },\n            {\n              \"name\": \"etag\",\n              \"description\": \"\",\n              \"type\": \"text\"\n            },\n            {\n              \"name\": \"email\",\n              \"description\": \"\",\n              \"type\": \"email\"\n            },\n            {\n              \"name\": \"directMembersCount\",\n              \"description\": \"\",\n              \"type\": \"integer\"\n            }\n          ]\n        }\n      ]\n    }\n  },\n  \"mapping\": {\n    \"objectTypeMappings\": [\n      {\n        \"objectTypeName\": \"Google Groups\",\n        \"selector\": \"api_response\",\n        \"description\": \"Mapping for API Response\",\n        \"attributesMapping\": [\n          {\n            \"attributeName\": \"Name\",\n            \"attributeLocators\": [\n              \"name\"\n            ]\n          },\n          {\n            \"attributeName\": \"ExternalId\",\n            \"attributeLocators\": [\n              \"id\"\n            ],\n            \"externalIdPart\": true\n          },\n          {\n            \"attributeName\": \"etag\",\n            \"attributeLocators\": [\n              \"etag\"\n            ]\n          },\n          {\n            \"attributeName\": \"email\",\n            \"attributeLocators\": [\n              \"email\"\n            ]\n          },\n          {\n            \"attributeName\": \"directMembersCount\",\n            \"attributeLocators\": [\n              \"directMembersCount\"\n            ]\n          }\n        ]\n      }\n    ]\n  }\n}",
